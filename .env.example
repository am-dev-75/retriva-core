# .env.example - Template for Retriva environment variables
# Copy this file to .env and fill in your values

# Development environment (optional)
# VIRTUAL_ENV="/home/llandre/.venvs/retriva-v0.1"
# PYTHONPATH="./src"

# --- API KEYS ---
# Main API key fallback for all services if specific keys are omitted
OPENROUTER_OPENAI_API_KEY="put your key here"

# Specific API keys (optional, falls back to OPENROUTER_OPENAI_API_KEY)
# EMBEDDING_OPENAI_API_KEY=""
# CHAT_OPENAI_API_KEY=""
# VISUAL_OPENAI_API_KEY=""
# RETRIEVAL_RERANK_API_KEY=""

# --- PORTS ---
INGESTION_API_PORT=8000
OPENAI_API_PORT=8001
UI_PORT=3000

# --- STORAGE AND PERSISTENCE ---
# STORAGE_PATH="./storage"
# KB_MAPPING_DB="./storage/kb_mappings.db"
# ARTIFACTS_PATH="./storage/artifacts"
# RETRIVA_CONSTITUTION="./.agent/rules/retriva-constitution.md"

# --- QDRANT VECTOR STORE ---
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION_NAME="retriva_chunks"

# --- INGESTION PIPELINE (v2) ---
TIKA_SERVER_URL="http://localhost:9998"
OCRMYPDF_ENABLED=true
OCRMYPDF_LANGUAGE="eng+ita"
OCRMYPDF_DESKEW=true
OCRMYPDF_ROTATE_PAGES=true
V2_PRIMARY_PARSER="docling"
ACCELERATOR_DEVICE="cpu"  # cpu, cuda, mps, auto

# --- EMBEDDING MODEL ---
EMBEDDING_BASE_URL="https://openrouter.ai/api/v1"
EMBEDDING_MODEL="baai/bge-m3"
EMBEDDING_DIMENSION=1024

# --- CHAT MODEL ---
CHAT_BASE_URL="https://openrouter.ai/api/v1"
CHAT_MODEL="qwen/qwen3.5-27b"
CHAT_TEMPERATURE=0.0
CHAT_TOP_P=0.9

# --- VISUAL MODEL ---
VISUAL_BASE_URL="https://openrouter.ai/api/v1"
VISUAL_MODEL="qwen/qwen3-vl-32b-instruct"
VISUAL_MAX_TOKENS=2048
VISUAL_TEMPERATURE=0.0

# --- RETRIEVAL AND RERANKING ---
RETRIEVER_TOP_K=100

# Two-stage retrieval (Reranking)
ENABLE_RETRIEVAL_RERANKING=true
RETRIEVAL_RERANK_MODEL="cohere/rerank-v3.5"
RETRIEVAL_RERANK_BASE_URL="https://openrouter.ai/api/v1"
RETRIEVAL_RERANK_CANDIDATES=100
RETRIEVAL_RERANK_TOP_N=30
RETRIEVAL_RERANK_BATCH_SIZE=100
RETRIEVAL_RERANK_MAX_LENGTH=4096

# --- HYBRID RETRIEVAL SELECTION ---
ENABLE_HYBRID_RETRIEVAL_SELECTION=true
HYBRID_RERANK_KEEP_TOP_M=4
HYBRID_VECTOR_KEEP_TOP_L=2

# --- INDEXING ---
INDEXING_BATCH_SIZE=100
MAX_CHUNK_CHARS=2000
CHUNK_OVERLAP=200

# --- CITATION METADATA ---
CITATION_SNIPPET_SIZE=2000
MAX_CITATIONS=25
MAX_METADATA_PER_CITATION=0

# --- EXTENSIONS ---
# Comma-separated dotted module paths for extension discovery
# RETRIVA_EXTENSIONS="my_extension.module"

# --- INTERNAL ---
ENABLE_INTERNAL_PROFILER=false

# --- LEGACY / OTHER ---
# MIRROR_BASE_PATH="./mirror"
# CANONICAL_BASE_URL="https://wiki.example.com"
# LOCAL_OPENAI_API_KEY="sk-mock-key"
